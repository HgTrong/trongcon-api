PORT=8080

JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168

DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=trongcon
DB_PORT=5432
DB_SSLMODE=disable
DB_TIMEZONE=UTC

# AWS S3 (upload ảnh chung: categories / articles / common)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Prefix key trong bucket (mặc định: public/images/)
AWS_S3_PREFIX=public/images
# Tuỳ chọn: CDN / CloudFront URL thay vì URL S3 trực tiếp
AWS_S3_PUBLIC_BASE_URL=
